{
  "name": "node-csv-importer",
  "version": "1.0.0",
  "description": "Generic CSV importer for PostgreSQL using YAML import profiles.",
  "main": "src/index.js",
  "bin": {
    "csv-importer": "src/index.js"
  },
  "scripts": {
    "start": "npm run start:prod",
    "start:prod": "node src/index.js --all",
    "start:test": "node src/index.js --all --mode test"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "pg": "^8.12.0",
    "pg-copy-streams": "^6.0.6",
    "yaml": "^2.5.1"
  },
  "engines": {
    "node": ">=18"
  },
